# ============================================
# BIDV Survey System - Environment Variables
# ============================================
# Copy file này thành .env và điền giá trị thực

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Firebase Admin SDK ---
# Tải Service Account JSON từ Firebase Console:
# Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Admin Whitelist ---
# Danh sách email được phép truy cập admin (phân cách bằng dấu phẩy)
ADMIN_EMAILS=admin@gmail.com,manager@gmail.com

# --- CORS ---
# Các domain được phép truy cập API (phân cách bằng dấu phẩy)
# Để trống hoặc * cho development
CORS_ORIGINS=http://localhost:3000

# --- Rate Limiting ---
# Số request tối đa cho /api/submit trong 15 phút
RATE_LIMIT_MAX=50
